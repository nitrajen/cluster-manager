# OTel Collector Admin Config
# Copy to config.env and fill in values. NEVER commit config.env.
#
# Usage: source config.env && ./manage.sh <command>

# --- Workspace Profiles (from ~/.databrickscfg) ---
# FEVM workspace where the Cluster Manager app is deployed
FEVM_PROFILE="FEVM_SERVERLESS_STABLE"
# Client workspace(s) where clusters run — space-separated for multi-workspace
CLIENT_WORKSPACE_PROFILES="DEMO WEST"

# --- Service Principal ---
SP_CLIENT_ID="YOUR_SP_CLIENT_ID"
# Token endpoint for M2M OAuth (on the FEVM workspace)
TOKEN_ENDPOINT="https://YOUR-WORKSPACE.cloud.databricks.com/oidc/v1/token"

# --- Secret Scope (on each client workspace) ---
SECRET_SCOPE="otel-collector"
SECRET_KEY="sp-client-secret"

# --- App ---
APP_URL="https://YOUR-APP.aws.databricksapps.com"
APP_NAME="cluster-manager"

# --- OTel Collector ---
VOLUME_PATH="/Volumes/main/cluster_manager/binaries"
INIT_SCRIPT_WORKSPACE_PATH="/Workspace/Users/YOU@databricks.com/init_scripts/init_otel_multinode.sh"
OTEL_INTERVAL="15s"
